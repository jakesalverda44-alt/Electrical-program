PORT=3001
DB_HOST=localhost
DB_PORT=5432
DB_NAME=electrical_crm
DB_USER=postgres
DB_PASS=postgres
JWT_SECRET=change_me_in_production_use_long_random_string
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Cloudinary — cloud file storage for large document uploads (plans, PDFs, etc.)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Anthropic — powers AI proposal builder (build-from-notes) and Kohler lead screenshot intake
ANTHROPIC_API_KEY=sk-ant-...

# Zapier webhooks — Generator Lead Pipeline automation
# Fired when a new email lead is created (contact_method = email)
ZAPIER_WEBHOOK_EMAIL_NEW_LEAD=https://hooks.zapier.com/hooks/catch/...
# Fired when a new phone lead is created (contact_method = phone)
ZAPIER_WEBHOOK_PHONE_NEW_LEAD=https://hooks.zapier.com/hooks/catch/...
# Fired when a lead moves to the "quoted" stage
ZAPIER_WEBHOOK_QUOTED=https://hooks.zapier.com/hooks/catch/...
# Fired when a lead moves to the "site-scheduled" stage
ZAPIER_WEBHOOK_SITE_SCHEDULED=https://hooks.zapier.com/hooks/catch/...
