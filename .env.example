# ── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=electrical_crm
DB_USER=postgres
DB_PASS=postgres

# ── Auth ─────────────────────────────────────────────────────────────────────
# Long random string used to sign JWTs — generate with: openssl rand -base64 48
JWT_SECRET=change_me_in_production_use_long_random_string

# Long-lived key for automation / browser-extension lead creation. Sent as the
# "X-API-Key" header and accepted only on POST /api/leads. Generate with:
# openssl rand -base64 48. Leave unset to disable API-key auth (JWT only).
AUTOMATION_API_KEY=

# ── Initial account bootstrap ─────────────────────────────────────────────────
# Used ONCE, only when the users table is empty, to create the first owner login
# (see backend/src/migrate.ts). No credentials are committed to the repo. Leave
# unset to skip seeding (e.g. when restoring an existing database).
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Administrator

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ── Google Drive ─────────────────────────────────────────────────────────────
# Service account JSON (single-line) for Drive folder automation
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ── Cloudinary ───────────────────────────────────────────────────────────────
# Cloud file storage for large document uploads (plans, PDFs, etc.)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Anthropic ────────────────────────────────────────────────────────────────
# Powers AI proposal builder (build-from-notes) and Kohler lead screenshot intake
ANTHROPIC_API_KEY=sk-ant-...

# ── Zapier — Generator Lead Pipeline ─────────────────────────────────────────
# Fired when a new email lead is created (contact_method = email)
ZAPIER_WEBHOOK_EMAIL_NEW_LEAD=https://hooks.zapier.com/hooks/catch/...
# Fired when a new phone lead is created (contact_method = phone)
ZAPIER_WEBHOOK_PHONE_NEW_LEAD=https://hooks.zapier.com/hooks/catch/...
# Fired when a lead moves to the "quoted" stage
ZAPIER_WEBHOOK_QUOTED=https://hooks.zapier.com/hooks/catch/...
# Fired when a lead moves to the "site-scheduled" stage
ZAPIER_WEBHOOK_SITE_SCHEDULED=https://hooks.zapier.com/hooks/catch/...
